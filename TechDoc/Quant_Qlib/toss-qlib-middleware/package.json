{
  "name": "toss-qlib-middleware",
  "version": "0.1.0",
  "private": true,
  "description": "TOSS Open API 인증/시세 데이터를 Qlib 파이프라인에 연동하는 Node.js/TypeScript 미들웨어 (Redis 캐시). 주문 실행(트레이딩)은 포함하지 않음 — src/trading/README.md 참고.",
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "export:qlib": "tsx src/cli.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
