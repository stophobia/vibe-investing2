PORT=4000

# 토스증권 WTS 로그인 후 설정 > Open API 메뉴에서 발급받은 값
# (../../../Toss/.env.example, ../../../Toss/GUIDE.md 와 동일한 키 이름)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# ../../../Toss/src/toss.js, ../../../Toss/GUIDE.md 기준으로 확인된 값. 바뀔 수 있으니
# https://developers.tossinvest.com/docs 로 최신 여부를 확인할 것
TOSS_BASE_URL=https://openapi.tossinvest.com
TOSS_TOKEN_PATH=/oauth2/token
TOSS_CANDLES_PATH=/api/v1/candles
TOSS_PRICES_PATH=/api/v1/prices

REDIS_URL=redis://127.0.0.1:6379

# 토큰 유효기간은 24시간(86400초)이고 refresh token이 없다. 만료 몇 초 전에
# 선제적으로 재발급할지 (기본 1시간 안전마진)
TOKEN_SAFETY_MARGIN_SEC=3600
# 확정된 과거 캔들 캐시 TTL — 하루
CANDLE_TTL_HISTORICAL_SEC=86400
# 당일(미확정) 캔들 캐시 TTL — 짧게
CANDLE_TTL_TODAY_SEC=30
# 현재가 캐시 TTL — 실시간성이 필요하므로 짧게
PRICE_TTL_SEC=5
INSTRUMENTS_TTL_SEC=86400

# Qlib dump_bin.py로 넘길 CSV 출력 경로 (Qlib 가이드 7.1/7.2절 형식과 동일)
QLIB_CSV_EXPORT_DIR=./csv_kr
