@misc{kim2026_decoupling,
  author    = {Kim, HoKwang},
  title     = {Directional Decoupling: Volatility-Ratio-Driven Beta Compression in the
               {BNB}-{ETH} Pair, May 2022 -- April 2026},
  year      = {2026},
  month     = may,
  day       = {12},
  publisher = {SSRN},
  type      = {SSRN Working Paper},
  number    = {6750298},
  doi       = {10.2139/ssrn.6750298},
  url       = {https://ssrn.com/abstract=6750298},
  abstract  = {Documents an instance of channel-specific beta change in BNB-ETH, May 2022
               to April 2026. Static beta falls 16.9 percent (0.643 to 0.534) while the
               Pearson correlation is essentially unchanged (0.731 to 0.731). A formal
               variance decomposition attributes 100 percent of the beta change to the
               volatility-ratio channel. DCC-GARCH dynamic-conditional-beta confirms the
               direction. Formalizes 'directional decoupling' as a distinct phenomenon from
               co-movement weakening.},
  keywords  = {beta decomposition, volatility ratio, directional decoupling, BNB, Ethereum,
               cryptocurrency, DCC-GARCH, variance decomposition, rolling beta, correlation},
  note      = {ORCID: 0009-0002-0962-2175}
}
