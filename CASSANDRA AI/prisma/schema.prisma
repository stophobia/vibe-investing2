generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 회사 (상장사) ───
model Corp {
  id          String   @id @default(uuid())
  corpCode    String   @unique @db.VarChar(8)
  stockCode   String?  @db.VarChar(6)
  companyName String
  formerNames String[] @default([]) // 이전 법인명 목록
  market      String   @default("KOSDAQ")
  marketCap   BigInt?
  isAdmin     Boolean  @default(false)
  delistedAt  DateTime?
  createdAt   DateTime @default(now())

  // 관계
  personRelations CorpPersonRelation[]
  fundRelations   CorpFundRelation[]
  filings         Filing[]
  signals         Signal[]
  corpEvents      CorpEvent[]

  @@index([companyName])
  @@index([corpCode])
}

// ─── 인물 (자연인) ───
// 동명이인 구분: name + birthDate → personUid = "P-{YYYYMMDD}-{seq}"
model Person {
  id        String   @id @default(uuid())
  personUid String   @unique
  name      String
  birthDate String?  // "1972.03.29" — 동명이인 구분키
  bio       String?  // "전 사이월드제트 CFO, 현 인트로메딕 상무이사"
  aliases   String[] @default([])
  flags     String[] @default([]) // ["blacklist", "suspicious"]
  createdAt DateTime @default(now())

  corpRelations CorpPersonRelation[]
  fundRelations FundPersonRelation[]

  @@index([name])
  @@index([birthDate])
}

// ─── 동명이인 그룹 (name 기반 묶음) ───
model SameNameGroup {
  id       String   @id @default(uuid())
  name     String   // 동명이인 그룹명
  personIds String[] @default([]) // Person.personUid 배열
  note     String?  // 구분 설명
  createdAt DateTime @default(now())

  @@index([name])
}

// ─── 법인/조합 (SPC, 신기술조합, 투자조합 등) ───
model Fund {
  id       String   @id @default(uuid())
  fundUid  String   @unique
  name     String
  fundType String   @default("spc") // spc, tech_assoc, invest_assoc, shell
  flags    String[] @default([])
  createdAt DateTime @default(now())

  corpRelations   CorpFundRelation[]
  personRelations FundPersonRelation[]

  @@index([name])
}

// ─── 인물-회사 관계 ───
model CorpPersonRelation {
  id            String   @id @default(uuid())
  personId      String
  corpId        String
  role          String   // "CEO", "DIRECTOR", "AUDITOR", "LARGEST_HOLDER", "INSIDER"
  description   String?  // 부연 설명
  since         DateTime?
  until         DateTime?
  source        String?  // 출처 (뉴스 URL, DART rcept_no 등)
  person        Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  corp          Corp     @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([corpId])
}

// ─── 법인-회사 관계 ───
model CorpFundRelation {
  id           String   @id @default(uuid())
  fundId       String
  corpId       String
  relationType String   // "CB_ACQUIRER", "LARGEST_HOLDER", "INVESTOR", "ACQUIRER"
  description  String?
  amount       BigInt?
  pct          Float?
  at           DateTime?
  source       String?
  fund         Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  corp         Corp     @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([fundId])
  @@index([corpId])
}

// ─── 법인-인물 관계 (실질지배) ───
model FundPersonRelation {
  id       String @id @default(uuid())
  fundId   String
  personId String
  role     String // "BENEFICIAL_OWNER", "REPRESENTATIVE"
  fund     Fund   @relation(fields: [fundId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([fundId])
  @@index([personId])
}

// ─── 공시 이벤트 ───
model Filing {
  id            String   @id @default(uuid())
  rceptNo       String   @unique @db.VarChar(14)
  corpId        String
  filingType    String   // "CB_ISSUANCE", "BW_ISSUANCE", "MAJORITY_HOLDER_CHANGE", etc.
  title         String
  summary       String?  // 요약 설명
  filedAt       DateTime
  sourceUrl     String?
  involvedPeople String[] @default([])
  involvedFunds  String[] @default([])
  corp          Corp     @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, filedAt])
  @@index([filedAt])
}

// ─── 신호 발화 ───
model Signal {
  id        String   @id @default(uuid())
  corpId    String
  ruleName  String
  score     Float
  detail    String?
  firedAt   DateTime @default(now())
  corp      Corp     @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, firedAt])
  @@index([firedAt])
}

// ─── 검색 로그 (실시간 검색어) ───
model SearchLog {
  id        String   @id @default(uuid())
  query     String
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query])
}

// ─── 게시판 (제보·분석요청) ───
model BoardPost {
  id          String   @id @default(uuid())
  authorName  String   @default("익명")
  password    String   // 게시글 수정/삭제용 비밀번호 (해시)
  title       String
  content     String
  category    String   @default("REPORT") // REPORT | ANALYSIS_REQUEST | DISCUSSION
  targetCorp   String? // 제보 대상 회사명
  targetPerson String? // 제보 대상 인물명
  status      String   @default("PENDING") // PENDING | REVIEWED | RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@index([status])
}

// ─── 집단 평가 투표 ───
model EntityVote {
  id         String   @id @default(uuid())
  entityType String   // "person" | "fund" | "corp"
  entityUid  String   // Person.personUid / Fund.fundUid / Corp.corpCode
  entityName String   // 표시용 이름
  vote       String   // "bad_ass" | "good" | "neutral"
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityUid])
  @@index([createdAt])
}

// ─── 평가 댓글 ───
model EntityComment {
  id         String   @id @default(uuid())
  entityType String   // "person" | "fund" | "corp"
  entityUid  String
  entityName String
  authorName String   @default("익명")
  password   String?  // 수정/삭제용 비밀번호 해시
  content    String
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityUid])
  @@index([createdAt])
}

// ─── 회사 이벤트 (법인명 변경, 사업목적 추가 등) ───
model CorpEvent {
  id        String   @id @default(uuid())
  corpId    String
  eventType String   // "NAME_CHANGE" | "PURPOSE_ADDITION" | "DIRECTOR_CHANGE" | "CAPITAL_INCREASE" | "CB_ISSUANCE" | "MERGER" | "SPLIT"
  detail    String   // 상세 내용
  occurredAt DateTime
  sourceUrl String?
  corp      Corp     @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, occurredAt])
  @@index([eventType])
}

// ─── 경제지표 스냅샷 (Naver Finance 크롤링) ───
model MarketSnapshot {
  id        String   @id @default(uuid())
  category  String   // "TOP_VOLUME" | "TOP_TURNOVER" | "TOP_GAINERS" | "TOP_SEARCH" | "VOLUME_PLUNGE"
  data      Json     // { stocks: [{ rank, name, code, price, change, volume }] }
  stats     Json?    // { avgChange, gainerCount, loserCount, totalVolume }
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([createdAt])
}

// ─── 사용자 계정 ───
model AppUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  role         String   @default("user") // user | admin
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?

  loginHistory LoginHistory[]
}

// ─── 로그인 이력 ───
model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())
  user      AppUser? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([email])
}

// ─── 페이지 방문자 통계 ───
model PageView {
  id        String   @id @default(uuid())
  path      String   // 방문 경로
  ip        String?
  userAgent String?
  userId    String?  // 로그인 사용자
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

// ─── 검색 캐시 인덱스 (GitHub ↔ DB 동기화) ───
model SearchCache {
  id          String   @id @default(uuid())
  type        String   // "person" | "company" | "keyword"
  query       String   // 검색어
  githubPath  String   // Dart_Data/person-results/{name}.json
  resultCount Int      // 결과 건수
  searchCount Int      @default(1) // 누적 검색 횟수
  period      Int      @default(12) // 검색 기간(개월)
  lastSearched DateTime @default(now())
  expiresAt   DateTime // 캐시 만료일
  createdAt   DateTime @default(now())

  @@unique([type, query, period])
  @@index([type, query])
  @@index([lastSearched])
}
