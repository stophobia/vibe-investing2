# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# DeepSeek API key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=
# DeepSeek's OpenAI-compatible endpoint (override only for self-hosted/proxy)
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat (V3) or deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# One of: buffett, dalio, wood
DEFAULT_PERSONA=buffett

# Random string used to hash Telegram IDs into anon_user_id (rotate to forget all users)
USER_ID_SALT=change-me-to-a-long-random-string

# SQLite path for the local UserProfileRepo (will be created automatically)
SQLITE_PATH=./data/aiinvestor.db

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ─── News collection (Finnhub → DeepSeek → Cloudflare Worker) ──────────────
# Finnhub free-tier API key (https://finnhub.io/dashboard) — required for news_collect timer
FINNHUB_KEY=
# Cloudflare Worker ingest endpoint (full URL incl. path)
CF_INGEST_URL=
# Shared secret used to sign POSTs to CF Worker (HMAC-SHA256 of "<ts>.<body>")
INGEST_SECRET=
# Optional: Alpha Vantage NEWS_SENTIMENT supplemental feed
ALPHAVANTAGE_KEY=
