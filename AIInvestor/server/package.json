{
  "name": "vibe-investing-server",
  "version": "0.1.0",
  "private": true,
  "description": "Vibe Investing Dashboard — Node.js/TypeScript backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.0",
    "yahoo-finance2": "^2.11.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.10.0",
    "typescript": "^5.6.0"
  }
}
